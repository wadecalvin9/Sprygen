spring:
  application:
    name: <%= projectName %>
  
  datasource:
    url: ${DB_URL:<%- dbConfig.url %>}
    username: ${DB_USER:<%- dbConfig.username %>}
    password: ${DB_PASS:<%- dbConfig.password %>}
    driver-class-name: <%- dbDriverClass %>
    hikari:
      maximum-pool-size: ${DB_POOL_SIZE:10}

  jpa:
  <%_ if (dbConfig.dialect) { _%>
    database-platform: <%- dbConfig.dialect %>
  <%_ } _%>
    hibernate:
      ddl-auto: ${DDL_AUTO:update}
    show-sql: false
    properties:
      hibernate:
        format_sql: true
<%_ if (database === 'h2') { _%>

  h2:
    console:
      enabled: true
      path: /h2-console
<%_ } _%>

<%_ if (hasMail) { _%>
  mail:
    host: ${MAIL_HOST:smtp.mailtrap.io}
    port: ${MAIL_PORT:2525}
    username: ${MAIL_USER:}
    password: ${MAIL_PASS:}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
<%_ } _%>

jwt:
  secret: ${JWT_SECRET:404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970_UPDATE_ME_IN_PROD}
  expiration: ${JWT_EXPIRATION:86400000} # 24h

app:
  cors:
    allowed-origins: ${CORS_ORIGINS:http://localhost:3000,http://localhost:4200,http://localhost:5173}

server:
  port: 8080
  error:
    include-message: always