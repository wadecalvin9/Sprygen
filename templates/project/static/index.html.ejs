<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= projectName %></title>
  <meta name="description" content="<%= description %>" />
  <link rel="stylesheet" href="/assets/style.css" />
</head>
<body>
<div id="app">

  <!-- ===== LANDING PAGE ===== -->
  <div id="page-landing">
    <div class="landing-wrap">

      <!-- Brand header -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:48px;padding-bottom:16px;border-bottom:1px solid var(--border);">
        <div style="display:flex;align-items:center;gap:10px;">
          <div style="width:28px;height:28px;background:var(--primary);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:14px;">⚡</div>
          <span style="font-weight:700;font-size:0.95rem;"><%= projectName %></span>
        </div>
        <div style="display:flex;gap:8px;">
          <button class="btn btn-outline btn-sm" onclick="showPage('login')">Sign in</button>
          <button class="btn btn-primary btn-sm" onclick="showPage('register')">Get Started</button>
        </div>
      </div>

      <!-- Hero -->
      <div class="landing-hero">
        <div style="display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:99px;background:var(--primary-faint);border:1px solid rgba(45,164,78,0.2);margin-bottom:16px;">
          <span style="width:6px;height:6px;border-radius:50%;background:var(--primary);display:inline-block;"></span>
          <span style="font-size:0.75rem;color:var(--primary);font-weight:600;">Running on Spring Boot 3.x</span>
        </div>
        <h1>Your Spring Boot API<br/>is <span class="accent">live</span>.</h1>
        <p>
          Generated by Sprygen — includes JWT authentication, role-based access control,
          user profiles, and an admin panel out of the box.
        </p>
        <div class="landing-cta">
          <button class="btn btn-primary" onclick="showPage('register')">Create account →</button>
          <button class="btn btn-outline" onclick="showPage('login')">Sign in</button>
          <a href="/swagger-ui/index.html" class="btn btn-outline" target="_blank" style="margin-left:4px;">API Docs</a>
        </div>
        <div class="pills">
          <span class="pill">Spring Boot 3.x</span>
          <span class="pill">JWT Auth</span>
          <span class="pill">RBAC</span>
          <span class="pill">Spring Data JPA</span>
          <span class="pill">BCrypt</span>
          <span class="pill">Bean Validation</span>
        </div>
      </div>

      <!-- API reference table -->
      <div class="card">
        <div class="card-body">
          <div class="section-header" style="margin-bottom:16px;">
            <span class="section-title">API Reference</span>
            <a href="/swagger-ui/index.html" target="_blank" style="font-size:0.8rem;color:var(--primary);text-decoration:none;font-weight:500;">Open Swagger →</a>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr><th>Method</th><th>Endpoint</th><th>Description</th><th>Auth</th></tr>
              </thead>
              <tbody>
                <tr>
                  <td><span class="method method-post">POST</span></td>
                  <td class="mono">/api/v1/auth/register</td>
                  <td>Register new account</td>
                  <td><span class="badge badge-success">Public</span></td>
                </tr>
                <tr>
                  <td><span class="method method-post">POST</span></td>
                  <td class="mono">/api/v1/auth/login</td>
                  <td>Login and get JWT token</td>
                  <td><span class="badge badge-success">Public</span></td>
                </tr>
                <tr>
                  <td><span class="method method-get">GET</span></td>
                  <td class="mono">/api/v1/profile</td>
                  <td>Get own profile</td>
                  <td><span class="badge badge-user">Bearer</span></td>
                </tr>
                <tr>
                  <td><span class="method method-put">PUT</span></td>
                  <td class="mono">/api/v1/profile</td>
                  <td>Update profile (name, bio, avatar)</td>
                  <td><span class="badge badge-user">Bearer</span></td>
                </tr>
                <tr>
                  <td><span class="method method-put">PUT</span></td>
                  <td class="mono">/api/v1/profile/password</td>
                  <td>Change password</td>
                  <td><span class="badge badge-user">Bearer</span></td>
                </tr>
                <tr>
                  <td><span class="method method-get">GET</span></td>
                  <td class="mono">/api/v1/admin/users</td>
                  <td>List all users</td>
                  <td><span class="badge badge-admin">Admin</span></td>
                </tr>
                <tr>
                  <td><span class="method method-put">PUT</span></td>
                  <td class="mono">/api/v1/admin/users/{id}/role</td>
                  <td>Assign role to user</td>
                  <td><span class="badge badge-admin">Admin</span></td>
                </tr>
                <tr>
                  <td><span class="method method-delete">DELETE</span></td>
                  <td class="mono">/api/v1/admin/users/{id}</td>
                  <td>Delete user</td>
                  <td><span class="badge badge-admin">Admin</span></td>
                </tr>
                <tr>
                  <td><span class="method method-get">GET</span></td>
                  <td class="mono">/actuator/health</td>
                  <td>Health check</td>
                  <td><span class="badge badge-success">Public</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div style="margin-top:32px;padding-top:16px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;font-size:0.78rem;color:var(--text-dim);">
        <span>Generated with <a href="#" style="color:var(--primary);text-decoration:none;">Sprygen</a></span>
        <span><%= projectName %> · Spring Boot 3.x</span>
      </div>
    </div>
  </div>

  <!-- ===== LOGIN PAGE ===== -->
  <div id="page-login" class="hidden">
    <div class="auth-page">
      <div class="auth-container">
        <div class="auth-brand">
          <div class="logo-icon-lg">⚡</div>
          <h1><%= projectName %></h1>
          <p>Sign in to your account</p>
        </div>
        <div class="auth-card">
          <div id="login-alert" class="alert alert-error"></div>
          <form id="login-form">
            <div class="form-group">
              <label for="login-email">Email address</label>
              <input id="login-email" type="email" placeholder="you@example.com" required autocomplete="email"/>
            </div>
            <div class="form-group" style="margin-bottom:18px;">
              <label for="login-password">Password</label>
              <input id="login-password" type="password" placeholder="••••••••" required autocomplete="current-password"/>
            </div>
            <button type="submit" class="btn btn-primary btn-full" id="login-btn">Sign in</button>
          </form>
          <div class="divider"></div>
          <p style="text-align:center;font-size:0.82rem;color:var(--text-muted);">
            New here?
            <a href="#" onclick="showPage('register')" style="color:var(--primary);text-decoration:none;font-weight:600;">Create an account</a>
          </p>
          <p style="text-align:center;font-size:0.78rem;color:var(--text-dim);margin-top:8px;">
            <a href="#" onclick="showPage('landing')" style="color:var(--text-dim);">← Back to home</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== REGISTER PAGE ===== -->
  <div id="page-register" class="hidden">
    <div class="auth-page">
      <div class="auth-container">
        <div class="auth-brand">
          <div class="logo-icon-lg">⚡</div>
          <h1><%= projectName %></h1>
          <p>Create your account</p>
        </div>
        <div class="auth-card">
          <div id="register-alert" class="alert alert-error"></div>
          <form id="register-form">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
              <div class="form-group">
                <label for="reg-first">First name</label>
                <input id="reg-first" type="text" placeholder="John" required/>
              </div>
              <div class="form-group">
                <label for="reg-last">Last name</label>
                <input id="reg-last" type="text" placeholder="Doe" required/>
              </div>
            </div>
            <div class="form-group">
              <label for="reg-email">Email address</label>
              <input id="reg-email" type="email" placeholder="you@example.com" required autocomplete="email"/>
            </div>
            <div class="form-group" style="margin-bottom:18px;">
              <label for="reg-password">Password <span style="font-size:0.72rem;color:var(--text-dim);">Min 6 characters</span></label>
              <input id="reg-password" type="password" placeholder="••••••••" required minlength="6" autocomplete="new-password"/>
            </div>
            <button type="submit" class="btn btn-primary btn-full" id="register-btn">Create account</button>
          </form>
          <div class="divider"></div>
          <p style="text-align:center;font-size:0.82rem;color:var(--text-muted);">
            Already have an account?
            <a href="#" onclick="showPage('login')" style="color:var(--primary);text-decoration:none;font-weight:600;">Sign in</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== APP SHELL ===== -->
  <div id="page-app" class="layout hidden">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <div class="logo-icon">⚡</div>
        <span class="logo-text"><%= projectName %></span>
      </div>
      <nav class="sidebar-nav">
        <span class="nav-section-label">Menu</span>
        <a class="nav-link" id="nav-dashboard" onclick="navigate('dashboard')">
          <i class="icon">▦</i> Dashboard
        </a>
        <a class="nav-link" id="nav-profile" onclick="navigate('profile')">
          <i class="icon">◉</i> Profile
        </a>
        <span class="nav-section-label admin-only hidden">Administration</span>
        <a class="nav-link admin-only hidden" id="nav-admin" onclick="navigate('admin')">
          <i class="icon">⚙</i> Admin Panel
        </a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-widget">
          <div class="user-avatar" id="sidebar-avatar"></div>
          <div class="user-info">
            <div class="user-name" id="sidebar-name">—</div>
            <div class="user-role" id="sidebar-role"></div>
          </div>
        </div>
        <button class="btn btn-outline btn-full btn-sm" style="margin-top:8px;" onclick="logout()">Sign out</button>
      </div>
    </aside>

    <!-- Main -->
    <div class="main">

      <!-- Dashboard -->
      <div id="view-dashboard" class="hidden">
        <div class="topbar">
          <span class="topbar-title">Dashboard</span>
          <span id="topbar-date" style="font-size:0.8rem;color:var(--text-muted);"></span>
        </div>
        <div class="page">
          <div class="page-header">
            <h1>Welcome back, <span id="dash-name"></span></h1>
            <p>Account overview and API reference.</p>
          </div>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-icon">🔑</div>
              <div class="stat-value" id="stat-role">—</div>
              <div class="stat-label">Role</div>
            </div>
            <div class="stat-card admin-only hidden">
              <div class="stat-icon">👥</div>
              <div class="stat-value" id="stat-total-users">—</div>
              <div class="stat-label">Total Users</div>
            </div>
            <div class="stat-card admin-only hidden">
              <div class="stat-icon">🛡</div>
              <div class="stat-value" id="stat-admins">—</div>
              <div class="stat-label">Admins</div>
            </div>
          </div>

          <div class="card">
            <div class="card-body">
              <div class="section-header">
                <span class="section-title">API Endpoints</span>
                <a href="/swagger-ui/index.html" target="_blank" style="font-size:0.8rem;color:var(--primary);text-decoration:none;font-weight:500;">Swagger UI →</a>
              </div>
              <div class="table-wrap">
                <table>
                  <thead><tr><th>Method</th><th>Endpoint</th><th>Access</th></tr></thead>
                  <tbody>
                    <tr><td><span class="method method-post">POST</span></td><td class="mono">/api/v1/auth/register</td><td><span class="badge badge-success">Public</span></td></tr>
                    <tr><td><span class="method method-post">POST</span></td><td class="mono">/api/v1/auth/login</td><td><span class="badge badge-success">Public</span></td></tr>
                    <tr><td><span class="method method-get">GET</span></td><td class="mono">/api/v1/profile</td><td><span class="badge badge-user">Bearer</span></td></tr>
                    <tr><td><span class="method method-put">PUT</span></td><td class="mono">/api/v1/profile</td><td><span class="badge badge-user">Bearer</span></td></tr>
                    <tr><td><span class="method method-get">GET</span></td><td class="mono">/api/v1/admin/users</td><td><span class="badge badge-admin">Admin</span></td></tr>
                    <tr><td><span class="method method-put">PUT</span></td><td class="mono">/api/v1/admin/users/{id}/role</td><td><span class="badge badge-admin">Admin</span></td></tr>
                    <tr><td><span class="method method-delete">DELETE</span></td><td class="mono">/api/v1/admin/users/{id}</td><td><span class="badge badge-admin">Admin</span></td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Profile -->
      <div id="view-profile" class="hidden">
        <div class="topbar"><span class="topbar-title">Profile</span></div>
        <div class="page">
          <div class="profile-hero">
            <div class="profile-avatar-lg" id="profile-avatar-lg"></div>
            <div class="profile-hero-info">
              <h2 id="profile-hero-name"></h2>
              <p id="profile-hero-email"></p>
              <div style="margin-top:6px;" id="profile-hero-badge"></div>
            </div>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="card">
              <div class="card-body">
                <div class="card-title">Personal information</div>
                <p class="card-muted" style="margin-bottom:16px;">Update your name and bio</p>
                <div id="profile-alert" class="alert"></div>
                <form id="profile-form">
                  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                    <div class="form-group">
                      <label>First name</label>
                      <input id="pf-first" type="text" />
                    </div>
                    <div class="form-group">
                      <label>Last name</label>
                      <input id="pf-last" type="text" />
                    </div>
                  </div>
                  <div class="form-group">
                    <label>Bio</label>
                    <textarea id="pf-bio" rows="3" placeholder="Tell us about yourself…" style="resize:vertical;"></textarea>
                  </div>
                  <div class="form-group" style="margin-bottom:16px;">
                    <label>Avatar URL</label>
                    <input id="pf-avatar" type="url" placeholder="https://…" />
                  </div>
                  <button type="submit" class="btn btn-primary">Save changes</button>
                </form>
              </div>
            </div>

            <div class="card">
              <div class="card-body">
                <div class="card-title">Change password</div>
                <p class="card-muted" style="margin-bottom:16px;">Update your login password</p>
                <div id="pw-alert" class="alert"></div>
                <form id="password-form">
                  <div class="form-group">
                    <label>Current password</label>
                    <input id="pw-current" type="password" placeholder="••••••••" />
                  </div>
                  <div class="form-group">
                    <label>New password</label>
                    <input id="pw-new" type="password" placeholder="••••••••" />
                  </div>
                  <div class="form-group" style="margin-bottom:16px;">
                    <label>Confirm new password</label>
                    <input id="pw-confirm" type="password" placeholder="••••••••" />
                  </div>
                  <button type="submit" class="btn btn-primary">Update password</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Admin -->
      <div id="view-admin" class="hidden">
        <div class="topbar">
          <span class="topbar-title">Admin Panel</span>
          <span id="admin-user-count" style="font-size:0.8rem;color:var(--text-muted);"></span>
        </div>
        <div class="page">
          <div class="page-header">
            <h1>User Management</h1>
            <p>Manage roles and users in your application.</p>
          </div>
          <div class="card">
            <div class="card-body">
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>ID</th><th>Name</th><th>Email</th><th>Role</th><th>Joined</th><th>Actions</th>
                    </tr>
                  </thead>
                  <tbody id="admin-users-body">
                    <tr><td colspan="6" style="text-align:center;padding:24px;color:var(--text-muted);">Loading…</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div id="toast" class="toast"></div>
</div>

<script src="/assets/app.js"></script>
</body>
</html>
